  "success_wisdom": [
    {
      "id": "wisdom-Q01",
      "issue_id": "Q01",
      "food_name": "热奶茶",
      "text": "别试图用透支明天来填补今天的洞。喝完这杯，先睡一觉。天塌下来，也有高个子和不怕死的小强顶着，你只管打呼噜就行。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q02",
      "issue_id": "Q02",
      "food_name": "咖喱肠粉",
      "text": "怕弄坏画布所以不敢落笔？在城市里，没被酱汁弄脏过的肠粉是没有灵魂的。别把自己活成一张白纸，那会被猫抓破的。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q03",
      "issue_id": "Q03",
      "food_name": "鱼蛋粗面",
      "text": "螺丝钉也有它的咬合力。如果觉得枯燥，明天试着自己加一份辣椒酱。生活嘛，要么忍受平庸，要么辣到流泪。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q04",
      "issue_id": "Q04",
      "food_name": "双拼碳水",
      "text": "重复并不可怕，可怕的是你忘了自己可以决定酱汁的配比。既然都是无聊的碳水，那就让它们撞个满怀，撞出一个双倍的饱嗝。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q05",
      "issue_id": "Q05",
      "food_name": "冻柠茶",
      "text": "柠檬本就是酸的，你没法把它煮甜。把酸的挑出去，顾好你自己。至于那个像柠檬一样的朋友，让他去别人的杯里发酸吧。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q06",
      "issue_id": "Q06",
      "food_name": "菠萝油套餐",
      "text": "面具戴久了会粘在脸上。偶尔在猫面前，你可以把那层酥皮卸下来。毕竟在这个深夜，没人会因为你内心的苦涩而扣你工资。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q07",
      "issue_id": "Q07",
      "food_name": "冰火菠萝油",
      "text": "既然想跳出安稳，就得忍受黄油化开时的黏腻与不安。猫跳下高台时，也得忍受肚皮着地。优雅是装给别人看的，爽是自己的。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q08",
      "issue_id": "Q08",
      "food_name": "鸳鸯奶茶",
      "text": "强行提神的代价是彻底失眠。既然不知道选哪条路，那就把两条路搅合在一起，然后在这个疯狂的夜晚彻底放空。",
      "tone": "治愈中带一点毒舌"
    },
    {
      "id": "wisdom-Q09",
      "issue_id": "Q09",
      "food_name": "姜汁汤圆",
      "text": "嫉妒是因为你以为大家都在同一个碗里。其实你是姜，他是糖，没必要比。只要你是滚烫的，总会有人愿意为了你满头大汗。",
      "tone": "治愈中带一点毒舌"
